#include <stdio.h>
#include <stdlib.h>

/* run this program using the console pauser or add your own getch, system("pause") or input loop */

int main(int argc, char *argv[]) {
	
	int idade, mes, dia, diastotais = 0, continuar ;
	char nome [20];
	
	do{
		scanf("%s", &nome);
		scanf("%i", &idade);
		scanf("%i", &mes);
		scanf("%i", &dia);
		
		diastotais = (idade * 365 ) + (mes * 12) + (dia);
		
		printf("%s, Voce viveu %i dias. \n ", 
		nome, diastotais);
		
		printf("Quer continuar? \n");
		printf("1=Sim			\n");
		printf("2=Não 			\n");
		scanf("%i", &continuar);
	} while (continuar == 1);
	
	
	system("pause");
	
	return 0;
}
